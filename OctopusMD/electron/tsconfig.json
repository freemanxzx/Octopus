{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "../dist-electron",
    "resolveJsonModule": true,
    "lib": ["es2020", "dom"]
  },
  "include": ["**/*.ts"]
}

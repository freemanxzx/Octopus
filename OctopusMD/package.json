{
  "name": "octopus-md",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc --project electron/tsconfig.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist-electron/main.js\"",
    "electron:build": "vue-tsc -b && vite build && tsc --project electron/tsconfig.json && electron-builder"
  },
  "build": {
    "appId": "com.octopus.md",
    "productName": "Octopus MD",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@types/crypto-js": "^4.2.2",
    "@types/uuid": "^11.0.0",
    "axios": "^1.15.0",
    "browser-image-compression": "^2.0.2",
    "codemirror": "^6.0.2",
    "concurrently": "^8.2.2",
    "cropperjs": "^1.6.2",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "follow-redirects": "^1.15.11",
    "form-data": "^4.0.5",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "juice": "^11.1.1",
    "markdown-it": "^14.1.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mathjax3": "^5.2.0",
    "proxy-from-env": "^2.1.0",
    "qiniu-js": "^3.4.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.32",
    "vue-codemirror": "^6.1.1",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.6"
  }
}

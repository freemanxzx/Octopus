{
  "name": "octopus-md",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc --project electron/tsconfig.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist-electron/main.js\""
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "axios": "^1.15.0",
    "codemirror": "^6.0.2",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "juice": "^11.1.1",
    "markdown-it": "^14.1.1",
    "markdown-it-footnote": "^4.0.0",
    "vue": "^3.5.32",
    "vue-codemirror": "^6.1.1",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.6"
  }
}
